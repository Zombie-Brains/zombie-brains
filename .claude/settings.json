{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{
          "type": "command",
          "command": "bash hooks/session-start.sh",
          "timeout": 10,
          "statusMessage": "🧟 Loading brain..."
        }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{
          "type": "command",
          "command": "bash hooks/on-commit.sh",
          "async": true,
          "timeout": 10
        }]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [{
          "type": "command",
          "command": "bash hooks/on-edit.sh",
          "timeout": 8
        }]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [{
          "type": "command",
          "command": "bash hooks/on-error.sh",
          "async": true,
          "timeout": 10
        }]
      }
    ],
    "Stop": [
      {
        "hooks": [{
          "type": "command",
          "command": "bash hooks/on-stop.sh",
          "async": true,
          "timeout": 10
        }]
      }
    ],
    "PreCompact": [
      {
        "hooks": [{
          "type": "command",
          "command": "bash hooks/pre-compact.sh",
          "timeout": 10
        }]
      }
    ]
  }
}
